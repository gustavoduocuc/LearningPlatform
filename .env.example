# Ejemplo de configuración para base de datos Oracle en producción
# Copia este archivo a .env y configura tus valores reales
# NUNCA incluyas el archivo .env en el control de versiones

# Conexión Oracle
# Formato: jdbc:oracle:thin:@//host:port/serviceName
ORACLE_DB_URL=jdbc:oracle:thin:@//oracle.example.com:1521/LEARNINGDB

# Credenciales de base de datos
ORACLE_DB_USERNAME=learning_user
ORACLE_DB_PASSWORD=your_secure_password_here
